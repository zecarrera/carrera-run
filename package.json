{
  "name": "carrera-run-dashboard",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @carrera-run/api\" \"npm run dev --workspace @carrera-run/web\"",
    "build": "npm run build --workspace @carrera-run/api && npm run build --workspace @carrera-run/web",
    "start": "npm run start --workspace @carrera-run/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
