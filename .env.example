STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:4000/api/auth/strava/callback
STRAVA_SCOPES=read,activity:read_all
SESSION_SECRET=replace_with_a_long_random_value
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=carrera_run

# Set to "true" to skip real Strava OAuth and use mock activity data locally.
# This is set automatically by `npm run dev:local` — no need to set it manually.
# STRAVA_MOCK=true

# LLM / Coach — defaults to local Ollama. For production use an OpenAI-compatible provider:
# e.g. OpenAI:   LLM_BASE_URL=https://api.openai.com/v1  LLM_API_KEY=sk-...  COACH_MODEL=gpt-4o-mini
# e.g. Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_API_KEY=...  COACH_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
COACH_MODEL=llama3.1:8b

# YouTube Data API v3 — optional. When set, video recommendations are fetched
# dynamically from YouTube (filtered by user's preferred channels).
# When unset, a static curated list is used as fallback (no API calls made).
# Get a key at: https://console.cloud.google.com/ — enable "YouTube Data API v3"
# YOUTUBE_API_KEY=AIza...
